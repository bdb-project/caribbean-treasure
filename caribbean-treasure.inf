! Room 10: Clearing
!========================================
Object room10 "Clearing"
with
  description "This large clearing is surrounded by thick vegetation to the north and south and the vegetation thins out to the east. You can hear the ocean to the west. There are faint tracks in each of those directions.",
  n_to room18,
  s_to room07,
  e_to room11,
  w_to room09,
  before
  [;
    Listen:
      print_ret (string)HEAR_OCEAN_WAVES;
  ],
has light;

!----------------------------------------
! Clearing
!----------------------------------------
Object "clearing" room10
with
  name 'large' 'clearing',
  description "You can see no obvious reason for the clearing. It doesn't appear to be man-made, so maybe the soil is too sandy for the vegetation to take root.",
