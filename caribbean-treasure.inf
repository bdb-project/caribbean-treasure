has scenery;

!----------------------------------------
! Bearded man
!----------------------------------------
Object castaway "bearded man" room20
with
  name 'man' 'castaway' 'strange' 'bearded' 'individual' 'dirty' 'smelly' 'hermit',
  description "He's a strange, bearded individual dressed in rags that are both dirty and smelly. He looks like a castaway.",
  life
  [;
    Ask:
      wn = consult_from;
      switch (NextWord())
      {
        'castaway':
          "~Are ya talkin' about me? I ain't a castaway. I just like a bit of seclusion.~";
        'fire', 'firepit', 'fireplace', 'pit':
          "~I have to light a fire at night to keep them pirate ghosts away.~";
        'flippers':
          "~They're mine. Get your own.~ You sincerely doubt that your flippers will fit his small feet, but he might not realise that yet, as he probably hasn't tried them on.";
        'ghost', 'ghosts':
          "~If ya don't light a fire at night, them pirate ghosts come and haunt ya. They're right creepy. They'll scare the bejesus outta ya.~";
        'him', 'himself':
          "~None of your business.~";
        'knife':
          "~It's mine. I need it to scare off them pirate ghosts.~";
        'me', 'myself', 'self':
          "~Never seen ya before in me life.~";
        'pirate', 'pirates':
          "~Ain't no pirates 'round 'ere. Only dead ones...and their ghosts.~";
        'scuba', 'gear':
          "~It's mine. Get your own.~ Now you know damn well that he's lying, as that's your stolen scuba gear.";
        'ship', 'shipwreck', 'wreck':
          "~I ain't seen no shipwrecks.~ If he hasn't found any shipwrecks, then why does he need your scuba gear?";
        'treasure':
          "~I don't know nothin' about no treasure.~ Hmm, he looked a bit sheepish when he said that. You think he must know something, but he's not letting on.";
        default:
          "~I don't know nothin' about that.~ This castaway is certainly not very friendly.";
      }
    Attack:
      "He might not be very friendly, but he's done you no harm, so leave him alone.";
    Give:
      if (noun == parchment or glasses)
        print "I don't think you should give ", (ThatOrThose)second, "  away. You might need ";
      if (noun == parchment)
        "it. Maybe you could show it to him to see if you get a reaction.";
      if (noun == glasses)
        "them again if the lantern goes out.";
      "~If it ain't rum, I ain't interested.~";
    Show:
      if (noun == parchment)
        "He squints. ~Where'd ya get that? I've been lookin' for...er...looks like rubbish. I'll take it off your hands if ya don't want it.~";
      "~I'm not interested in your trinkets.~ He didn't look very carefully. You don't think he can see very well without his glasses.";
    Talk:
      "~Who are you?~ You explain that your name is Alan Simmons, but you think it best not to mention your objective on the island.";
  ],
  before
  [;
    AskFor:
      if (second == knife or scuba or flippers or rags)
      {
        if (second hasnt pluralname)
          print "~This is";
        else
          print "~These are";
        " mine. Get your own.~";
      }
      "~I ain't got none.~";
    Smell:
      "Phew! He smells of dirt and grime and really bad body odour.";
  ],
  !The parser converts ASK CREATURE FOR NOUN into CREATURE, GIVE NOUN TO ME.
  !This is a hack to convert it back again.
  orders
  [;
    Give:
      <<AskFor self noun>>;
  ],
  each_turn
  [;
    if (clothes has worn)
    {
      remove self;
      "^The castaway is unexpectedly frightened by your appearance, as if he's seen a ghost. He carefully edges around you, then leaves the cave and runs away into the vegetation.";
    }
  ],
has animate transparent;

