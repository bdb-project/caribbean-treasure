!========================================
! Room 25: Shipwreck
!========================================
Object room25 "Shipwreck"
with
  description "The enormous carcass of the wreck is now around you. The long wooden structures of the galleon are completely covered with marine encrustations and there are numerous fish that flee in fear as you pass.",
  out_to room24,
  before
  [;
