with
  name 'packed-earth' 'packed' 'earth' 'soil' 'dirt' 'floor' 'ground',
  description "The soil in the cave is packed solid from years of use.",
  before
  [;
    Dig:
      "You can't dig it with your bare hands. You'd need a spade or a shovel.";
  ],
has scenery;

