with
  article THE,
  name 'bottom' 'of' 'hill' 'marsh' 'marshy' 'runoff',
  description "The area at the bottom of the hill is quite marshy.",
  before
  [;
    Climb:
      <<Go FAKE_U_OBJ>>;
  ],
has scenery;

!----------------------------------------
! Steep slope (floating object)
!----------------------------------------
Object "steep slope"
with
  name 'steep' 'slope' 'rocky',
  description "The slope is quite rocky.",
  before
  [;
    Climb:
      if (self in room12)
        "Up or down?";
      if (self in room11)
        <<Go FAKE_U_OBJ>>;
      else
        <<Go FAKE_D_OBJ>>;
  ],
  found_in room11 room12 room21,
has scenery;

!----------------------------------------
! Insects
!----------------------------------------
Object "insects" room11
with
  name 'swarms' 'clouds' 'of' 'insects' 'mosquitoes' 'mosquitos' 'bugs',
  description "The insects come in all shapes and sizes. They buzz around in constantly moving clouds. You'd better not hang around here for too long, in case there are any malaria-carrying mosquitoes.",
  before
  [;
    if (action ~= ##Attack or ##Examine)
      "Leave them alone. They're not going to help you find any treasure.";
    Attack:
      "You try swatting the insects, but there are thousands of them and they just fly out of the way.";
  ],
has pluralname scenery;

!========================================
! Room 12: Steep Slope
!========================================
Object room12 "Steep Slope"
with
  description "You're on a steep slope that climbs the side of the hill. You can climb up to reach the top or climb down to return to the marshy area at the bottom of the hill.",
  w_to room11,
  u_to room21,
  d_to room11,
  before
  [;
    Hint:
      if (stone hasnt moved)
        "That stone could come in handy if you need to break anything.";
  ],
has light;

!----------------------------------------
! Hill (floating object)
!----------------------------------------
Object "hill"
with
  name 'hill' 'rocky' 'peak',
  description
  [;
    print "You're ";
    if (self in room12)
      "half way up the hill.";
    else
      "at the top of the hill, where it culminates in a rocky peak overlooking a steep cliff to the east.";
  ],
  before
  [;
    Climb:
      if (self in room12)
        "Up or down?";
      else
        <<Go FAKE_D_OBJ>>;
  ],
  found_in room12 room21,
has scenery;

!----------------------------------------
! Stone
!----------------------------------------
Object stone "stone" room12
with
  name 'stone' 'good' 'solid' 'sharp' 'edges' 'fist-sized' 'fist' 'sized',
  description "It's a good solid stone with sharp edges. I'd say it's about fist sized.",
has;

!========================================
! Room 13: Foot of High Palisade
!========================================
Object room13 "Foot of High Palisade"
with
  description "You're at the foot of a high palisade that blocks your passage to the east. On the other side of the palisade, you can see a rock face. A faint path leads through the vegetation to the west.",
  e_to NEED_TO_CLIMB_OVER_PALISADE,
  w_to room07,
  u_to
  [;
    if (hanging_rope notin location)
      print_ret (string)PALISADE_IS_TOO_HIGH_TO_CLIMB;
    if (flippers has worn)
      print_ret (string)CANT_CLIMB_WEARING_FLIPPERS;
    move hanging_rope to room14;
    print (string)YOU_CLIMB_OVER_PALISADE;
    return room14;
  ],
  before
  [;
    Hint:
      if (hook in nothing || rope in nothing)
        "Explore the south side of the island and come back later.";
      if (room14 hasnt visited)
      {
        if (hanging_rope notin location && rope_with_hook in nothing)
          "Here's a knotty problem to be grappled with. If you're trying to climb over the palisade, try tying two things together.";
        if (hanging_rope notin location)
          "Throw the grappling hook over the palisade.";
        "Climb the rope.";
      }
  ],
has light;

!----------------------------------------
! Palisade (floating object)
!----------------------------------------
Object palisade "palisade"
with
  name 'palisade' 'fence' 'foot' 'of' 'vertical' 'high' 'wooden' 'stake' 'stakes' 'sharp' 'sharpened' 'point' 'defensive' 'wall' 'formidable' 'defence',
  description "The palisade consists of a fence of vertical wooden stakes fixed into the ground to form a defensive wall around an enclosure. Each stake is sharpened to a point at the top. You wonder who constructed it and why they would need such a formidable defence on an isolated tropical island.",
  before
  [;
    Climb, JumpOver:
      print_ret (string)PALISADE_IS_TOO_HIGH_TO_CLIMB;
  ],
  found_in room13 room14,
has scenery;

!----------------------------------------
! Rock face (floating object)
!----------------------------------------
Object "rock face"
with
  name 'foot' 'of' 'rock' 'face',
  description
  [;
    if (self in room13)
      "You can probably see it better from the other side of the palisade.";
    else
      "The rock face is too steep to climb, but it does have a small cave.";
  ],
  before
  [;
    Climb:
      if (self in room14)
        print_ret (string)TOO_STEEP_TO_CLIMB;
  ],
  found_in room13 room14,
has scenery;

!----------------------------------------
! Rope hanging from palisade
!----------------------------------------
Object hanging_rope "rope hanging from the palisade"
with
  name 'rope' 'hanging' 'from' 'palisade' 'fence',
  description "It's the rope you found at the beach. It's currently hooked over the top of the palisade, allowing you to climb over, if you're agile enough.",
  before
  [;
    Climb:
      <<Go FAKE_U_OBJ>>;
    Take:
      if (children(player) < MAX_CARRIED)
      {
        remove self;
        move rope_with_hook to player;
        PronounNotice(rope_with_hook);
        "You flick the rope a few times until you dislodge the hook. The rope and hook fall to the ground and you scoop it up into your arms.";
      }
  ],
has static;

!========================================
! Room 14: Foot of Rock Face
!========================================
Object room14 "Foot of Rock Face"
with
  description "You're on the east side of the palisade at the foot of a rock face to the east. The rock face is too steep to climb, but it does house a small cave.",
  e_to room15,
  w_to NEED_TO_CLIMB_OVER_PALISADE,
  u_to
  [;
    if (hanging_rope notin location)
      print_ret (string)PALISADE_IS_TOO_HIGH_TO_CLIMB;
    if (flippers has worn)
      print_ret (string)CANT_CLIMB_WEARING_FLIPPERS;
    move hanging_rope to room13;
    print (string)YOU_CLIMB_OVER_PALISADE;
    return room13;
  ],
  in_to room15,
  before
  [;
    Hint:
      if (room15 hasnt visited)
        print_ret (string)ENTER_CAVE;
  ],
has light;

!----------------------------------------
! Small cave (floating object)
!----------------------------------------
Object "small cave"
with
  name 'small' 'cave' 'recess',
  description "It's nothing more than a small recess gouged into the rock.",
  before
  [;
    Enter:
      if (self in room14)
        <<Go FAKE_E_OBJ>>;
    Exit:
      if (self in room15)
        <<Go FAKE_W_OBJ>>;
  ],
  found_in room14 room15,
has scenery;

!========================================
! Room 15: Inside Small Cave
!========================================
Object room15 "Inside Small Cave"
with
  description "This small cave is lit by the sun streaming in from the west. The sunlight reveals signs that it has been used for human habitation, but it's now abandoned.",
  w_to room14,
  out_to room14,
  before
  [;
    Hint:
      if (padlock in nothing)
        "Try opening the chest.";
      if (padlock has static)
        "That padlock looks pretty rusty, so it's probably not very strong.";
      if (chest hasnt open && lantern hasnt moved)
        "That chest isn't going to open itself, you know.";
  ],
has light;

!----------------------------------------
! Sunlight (floating object)
!----------------------------------------
Object "sunlight"
with
  article THE,
  name 'sunlight' 'bright' 'sun' 'light' 'daylight',
  description "You can see the bright daylight outside the entrance of the cave.",
  found_in room15 room16,
has scenery;

!----------------------------------------
! Large chest
!----------------------------------------
Object chest "large chest" room15
with
  name 'large' 'chest' 'trunk',
  invent
  [;
    if (inventory_stage == 2 && (self hasnt open || child(self) == 0))
      rtrue;
  ],
  description
  [;
    print "It's a large wooden chest reinforced by brass bands. ";
    <<Search self>>;
  ],
  before
  [;
    Open:
      if (self has locked)
      {
        if (padlock in nothing)
          move padlock to location;
        "There's a heavy padlock on the chest that prevents it from being opened.";
      }
    Take:
      "In your dreams. It's far too heavy to move, which makes you wonder how it got here.";
  ],
  with_key dummy_key,
has container openable lockable locked static;

!----------------------------------------
! Brass bands
!----------------------------------------
Object "brass bands" room15
with
  name 'brass' 'band' 'bands',
  description "These brass bands won't be playing any music any time soon.",
has pluralname scenery;

!----------------------------------------
! Rusty padlock
!----------------------------------------
Object padlock "rusty padlock"
with
  name 'padlock' 'lock' 'heavy' 'rusty',
  description
  [;
    print "It's a rusty old padlock that's ";
    if (self has static)
      "doing a good job of keeping the chest locked.";
    else
      "now broken from where you battered it with the stone.";
  ],
  before
  [;
    Attack:
      if (self hasnt static)
        "It's already broken.";
      if (second == nothing && stone in player)
      {
        print "(with the stone)^";
        second = stone;
      }
      if (second == nothing)
        "You'll have to tell me what to break it with.";
      if (second notin player)
        "You aren't carrying ", (the)second, ".";
      print "You bash away at the padlock with ", (the)second;
      if (second ~= stone)
        ", but it has no impact.";
      give self ~static;
      give chest ~locked;
      " until it eventually snaps and falls to the ground.";
    Open, Unlock:
      if (self has static)
        "You don't have the key. Even if you did, it looks like it's too rusty to open.";
      else
        "You've already broken it.";
    Take:
      if (self has static)
        "You can't. It's attached to the chest.";
  ],
has static;

!----------------------------------------
! Old lantern
!----------------------------------------
Object lantern "old lantern" chest
with
  article AN,
  name 'old' 'kerosene' 'lantern' 'lamp' 'wick',
  description
  [;
    print "It looks like an old kerosene lantern. It's ";
    if (self has light)
      "currently lit and emitting a dull yellow glow.";
    print "not currently lit, but ";
    if (self in player)
      print "you can hear the kerosene splooshing around inside and ";
    "the wick looks dry, so you should be able to light it.";
  ],
  before
  [;
    Burn:
      if (self has light)
        "It's already lit.";
      if (CantBeLit())
        rtrue;
      give self light;
      print_ret (string)YOU_FOCUS_GLASSES_LENS, "wick and adjust the beam of sunlight until you get a strong point of light. After a little while, the wick starts to smoulder, then springs into flame when the heat reaches the kerosene-drenched part of the wick. That should last awhile.";
    Drop:
      if (real_location == room16 or room17)
        "Don't drop it here or it'll get wet and you won't be able to use it.";
    Extinguish, SwitchOff:
      if (self hasnt light)
        "It's already extinguished.";
      give self ~light;
      "You blow out the naked flame and the glow from the lantern quickly dies.";
    SwitchOn:
      if (self has light)
        "It's already lit.";
      "It's not an automatic lantern. You'll need to find a way to light the wick.";
  ],
has buoyant;

!========================================
! Room 16: Inside Sea Cave
!========================================
Object room16 "Inside Sea Cave"
with
  description "You're inside a large sea cave. At the bottom of the cave, you can see pools of water and a lot of sand. You can see that the domed ceiling is full of cracks, but it's out of your reach. Although it's dark inside the cave, you can see bright daylight outside the cave to the west.",
  w_to room06,
  out_to room06,
  before
  [;
    Go:
      if (selected_direction == w_to or out_to)
      {
        self.time_left = 0;
        StopDaemon(self);
        rfalse;
      }
    Hint:
      if (DarkHints())
        rtrue;
      if (remains in location)
        "Examine the pirate's remains and take what you find.";
      if (parchment in nothing)
        "Be patient. If the water level rises, you'll be able to reach that ceiling.";
  ],
  daemon
  [ x y;
    self.time_left++;
    if (self.time_left < 6)
      rtrue;
    if (self.time_left < 10)
      "^Sea water is seeping into the cave and its level increases by the minute.";
    if (self.time_left == 10)
      "^The water level in the cave is now so high that you're forced to swim.";
    self.time_left = 0;
    StopDaemon(self);
    x = child(self);
    while (x)
    {
      y = sibling(x);!Save for next loop
      if (x has buoyant)
        move x to room17;
      x = y;
    }
    StartDaemon(room17);
    print "^There's a sudden rush of water and you struggle to stay afloat. Within moments, the water raises you to the domed ceiling of the cave and you can't get to the exit.^^";
    PlayerTo(room17);
    rtrue;
  ],
  time_left 0,
has;

!----------------------------------------
! Pools of sea water
!----------------------------------------
Object "pools of sea water" room16
with
  name 'pool' 'pools' 'of' 'sea' 'water',
  description "The pools contain sea water.",
  before
  [;
    Drink:
      print_ret (string)TOO_SALTY;
    Enter:
      "In a move reminiscent of your childhood, you paddle about in the small pools of sea water.";
  ],
has pluralname scenery;

!----------------------------------------
! Ceiling
!----------------------------------------
Object "ceiling" room16
with
  article THE,
  name 'domed' 'ceiling' 'dome' 'crack' 'cracks',
  description "The cracks in the domed ceiling are above your head and out of your reach.",
has scenery;

!----------------------------------------
! Remains of a pirate
!----------------------------------------
Object remains "remains of a pirate" room16
with
  article THE,
  name 'skeleton' 'remains' 'of' 'pirate' 'bones',
  description "It's nothing more than a skeleton wearing pirate's clothes.",
  before
  [;
    Take:
      "Ooh, gross! You can take his clothing, but leave the rest to rot in peace.";
  ],
has static;

!----------------------------------------
! Pirate's clothes
!----------------------------------------
Object clothes "pirate's clothes" room16
with
  name 'pirate^s' 'clothes' 'clothing' 'linen' 'shirt' 'blue' 'frock' 'coat' 'grey' 'gray' 'breeches' 'old' 'tatty',
  description "The pirate's clothes are extremely old and tatty. They consist of a linen shirt, blue frock coat and grey breeches.",
  before
  [;
    Take:
      if (children(player) < MAX_CARRIED && self has concealed)
      {
        give self ~concealed;
        remove remains;
        move skeleton to location;
      }
    Wear:
      if (room20 hasnt visited)
        "Are you planning on going to a fancy-dress party? You have no reason to wear a dead pirate's clothes.";
  ],
  after
  [;
    Drop:
      "You drop", (string)ALL_PIRATES_CLOTHES;
    Remove:
      "You remove", (string)ALL_PIRATES_CLOTHES, " You now look like yourself again.";
    Take:
      "You take", (string)ALL_PIRATES_CLOTHES;
    Wear:
      "You put on the shirt, then the breeches, then the coat. You now look like a pirate. ~Arrr! Shiver me timbers. Now where'd I put me treasure?~";
  ],
has clothing concealed pluralname;

!----------------------------------------
! Skeleton
!----------------------------------------
Object skeleton "skeleton"
with
  name 'skeleton' 'remains' 'of' 'pirate' 'bones',
  description "You can't tell now that his clothes have been removed, but this is the remains of a pirate.",
  before
  [;
    Take:
      "Leave him alone and show a little respect for the dead.";
  ],
has static;

!========================================
! Room 17: Near Ceiling of Cave
!========================================
Object room17 "Near Ceiling of Cave"
with
  description "The water level has raised due to a sudden ocean swell and this has lifted you until you're almost touching the ceiling of the cave. You're madly kicking your legs to stay afloat while struggling to hold the lantern above the water, but if the water rises any further, you will certainly drown, as you can no longer get to the exit. However, if you're patient, the water level will most likely drop when the swell abates.",
  d_to "Be patient, the water will recede when the ocean swell lowers.",
  before
  [;
    Dive:
      <<Go FAKE_D_OBJ>>;
    Hint:
      if (DarkHints())
        rtrue;
      if (parchment in nothing)
        "Have you examined the ceiling? Try reaching into the cavity.";
      "Be patient. What goes up must come down, even water.";
  ],
  daemon
  [ x y;
    self.time_left++;
    if (self.time_left < 5)
      rtrue;
    if (self.time_left < 6)
      "^The water is starting to recede.";
    self.time_left = 0;
    StopDaemon(self);
    x = child(self);
    while (x)
    {
      y = sibling(x);!Save for next loop
      if (x has buoyant)
        move x to room16;
      x = y;
    }
    StartDaemon(room16);
    print "^The water level suddenly drops and you once again find yourself standing on the bottom of the cave.^^";
    PlayerTo(room16);
    rtrue;
  ],
  time_left 0,
has water;

!----------------------------------------
! Ceiling
!----------------------------------------
Object "rocky ceiling" room17
with
  name 'domed' 'rock' 'rocky' 'ceiling' 'of' 'cave',
  description "When you examine the rocky ceiling, you discover a narrow cavity that extends lengthwise towards the back of the cave. Flotsam and jetsam could easily get stuck in there when the tide is high.",
has scenery;

!----------------------------------------
! Cavity
!----------------------------------------
Object "cavity" room17
with
  name 'cavity' 'deep' 'crack' 'narrow',
  description
  [;
    if (parchment in nothing)
      "You can see something in the cavity, but you can't see what it is in the dim light.";
    else
      "It's just a deep crack in the ceiling.";
  ],
  before
  [;
    ReachIn, Search:
      print "You reach into the cavity of the ceiling";
      if (parchment notin nothing)
        ", but don't find anything else.";
      move parchment to location;
      " and a parchment falls out.";
  ],
has scenery;

!----------------------------------------
! Sea water
!----------------------------------------
Object "sea water" room17
with
  article THE,
  name 'sea' 'water',
  description "The sea water is swirling all around you. You just hope that it doesn't get any higher.",
  react_after
  [;
    Drop:
      print (The)noun;
      if (noun has buoyant)
      {
        print " float";
        if (noun hasnt pluralname)
          print "s";
        " on the water.";
      }
      move noun to room16;
      print " sink";
      if (noun hasnt pluralname)
        print "s";
      " below the water.";
  ],
  before
  [;
    Drink:
      print_ret (string)TOO_SALTY;
  ],
has scenery;

!----------------------------------------
! Goat-skin parchment
!----------------------------------------
Object parchment "goat-skin parchment"
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'parchment' or 'goat-skin' or 'goat' or 'skin' or 'soggy' or 'treasure' or 'map')
    {
      i++;
      if (nw == 'treasure' && TestScope(treasure))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description
  [;
    print "It looks like a soggy treasure map. There's something written on it";
    if (self hasnt general)
      print ", so perhaps you should read it";
    ".";
  ],
  before
  [;
    Read:
      give self general;
      "On closer examination, it looks like a map of the island. There's an 'X' marked to the east of the island and some blurry writing that says, 'WITH IT YOU WILL FIND WEALTH. WITHOUT IT YOU WILL FIND DEATH.' That's pretty cryptic.";
  ],
has buoyant;

!========================================
! Room 18: Thick Vegetation
!========================================
Object room18 "Thick Vegetation"
with
  description "The vegetation is almost impenetrable at this point, but it thins out to the south and east.",
  s_to room10,
  e_to room19,
has light;

!========================================
! Room 19: Outside Dark Cave
!========================================
Object room19 "Outside Dark Cave"
with
  description "You're in front of a dark cave to the north. It's well hidden by the thick vegetation and you probably wouldn't have noticed it if not for the faint trail that comes from the west, then disappears into the cave.",
  n_to room20,
  w_to room18,
  in_to room20,
  before
  [;
    Hint:
      if (room20 hasnt visited)
        print_ret (string)ENTER_CAVE;
  ],
has light;

!----------------------------------------
! Trail
!----------------------------------------
Object "trail" room19
with
  name 'trail' 'faint',
  description "It comes from the west, then leads into the dark cave to the north.",
has scenery;

