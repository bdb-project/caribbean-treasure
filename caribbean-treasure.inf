! Vegetation (floating object)
!----------------------------------------
Object "vegetation"
with
  article THE,
  name 'vegetation' 'thick' 'leafy' 'vine' 'vines',
  description "The vegetation is mainly leafy vines hanging over the entrance to the cave.",
  found_in room19 room20,
has scenery;

!----------------------------------------
! Dark cave (floating object)
!----------------------------------------
Object "dark cave"
with
  name 'cave' 'entrance' 'small' 'dark' 'primitive' 'shelter',
  description
  [;
    print "It's a dark cave";
    if (self in room19)
      ", but you can't tell much more than that without going inside.";
    else
      " with a packed-earth floor. It's actually quite cosy and makes a good shelter from the elements outside.";
  ],
  before
  [;
    Enter:
      if (self in room19)
        <<Go FAKE_N_OBJ>>;
    Exit:
      if (self in room20)
        <<Go FAKE_S_OBJ>>;
  ],
  found_in room19 room20,
has scenery;

!========================================
! Room 20: Inside Dark Cave
!========================================
Object room20 "Inside Dark Cave"
with
  name 'small' 'cave',
  description "The small cave is clearly a primitive shelter. A straw mattress in one corner betrays a human presence and the remains of a firepit confirm that. A faint light can be seen beyond the thick vegetation that hides the entrance to the south.",
  s_to room19,
  out_to room19,
  before
  [;
    Hint:
      if (DarkHints())
        rtrue;
      if (castaway in self)
      {
        print "Ask the castaway about his belongings, the things you're looking for and anything else he mentions. ";
        if (clothes has concealed)
          "Come back when you've found something he's scared of.";
        else
          "Then it's time to play dress-ups.";
      }
  ],
has;

