!----------------------------------------
! Scuba gear
!----------------------------------------
Object scuba "scuba gear" room20
with
  article "your",
  name 'scuba' 'gear' 'oxygen' 'tank' 'respirator' 'mask',
  description "It's your scuba gear. It consists of an oxygen tank, respirator and mask.",
  before
  [;
    Disrobe:
      if (location == room24 or room25)
        "You can't remove the scuba gear while you're underwater, or you'll drown.";
    Take:
      if (castaway in location)
        print_ret (string)CASTAWAY_DRAWS_KNIFE, "points it towards your heart. ~Hands off me stuff or I'll do ya through.~";
  ],
has clothing;

!----------------------------------------
! Flippers
!----------------------------------------
Object flippers "flippers" room20
with
  article "a pair of",
  name 'pair' 'of' 'flippers',
  description "They're your flippers.",
  react_before
  [ destination;
    Go:
      if (self hasnt worn)
        rfalse;
      if (location has water)
        rfalse;
      destination = location.(direction_properties_array->selected_direction_index);
      if (destination ofclass Object && destination hasnt door && destination hasnt water)
        "It's too awkward to walk around wearing flippers.";
      rfalse;
  ],
  before
  [;
    Disrobe:
      if (location == room24 or room25)
        "You can't remove the flippers while you're underwater, or you won't be able to swim against the strong ocean currents.";
    Take:
      if (castaway in location)
        print_ret (string)CASTAWAY_DRAWS_KNIFE, "waves it in a threatening manner. ~Get ya own flippers or I'll turn ya into mince meat.~";
  ],
has buoyant clothing pluralname;

!========================================
! Room 21: Top of Cliff
!========================================
Object room21 "Top of Cliff"
with
  description "You're at the top of a hill on the east side of the island. The rocky peak reveals an impressive view over the ocean. There's a cliff to the east that looks down into the deep sea. There doesn't appear to be any rocks at the base of the cliff, as the ocean waves crash directly against the cliff wall many metres below. Unless you're silly enough to jump off the cliff, you can only go back down the steep slope of the hill that brought you here.",
  e_to
  [;
    if (parchment hasnt general)
      "You have no reason to make a death-defying leap into the ocean. Maybe later?";
    if (lantern in player)
      print_ret (string)LEAVE_LANTERN_BEHIND;
    print "The 'X' on the map was on this side of the island and this is the only way to get there. So, here goes nothing...^^";
    return room22;
  ],
  d_to room12,
  before
  [;
    Dive, Jump, Swim:
      <<Go FAKE_E_OBJ>>;
    Hint:
      if (parchment hasnt general)
        "You'll need a good reason to dive off that cliff. Knowing the location of the shipwreck would be a good reason.";
      if (scuba notin player || flippers notin player)
        "It's preferable to have your diving gear before you dive into the ocean.";
  ],
has light;

!----------------------------------------
! Cliff (floating object)
!----------------------------------------
Object "cliff"
with
  name 'cliff' 'cliffs' 'top' 'of' 'very' 'high' 'sheer' 'tall',
  description "It's a sheer cliff with very little in the way of hand-holds or foot-holds, so there's no way you'll be able to climb it.",
  before
  [;
    Climb:
      print_ret (string)TOO_STEEP_TO_CLIMB;
    Exit:
      if (self in room21)
        <<Jump>>;
  ],
  found_in room21 room22 room23,
has scenery;

