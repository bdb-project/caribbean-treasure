with
  description "You're at the bottom of a hill that climbs up a steep slope to the east. The runoff from the slope has made this area quite marshy and swarms of insects fill the air around you. You can avoid the insects by going back to the west.",
  e_to room12,
  w_to room10,
  u_to room12,
  before
  [;
    Listen:
      "You hear the buzzing of insects.";
  ],
has light;

