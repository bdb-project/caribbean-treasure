! Room 23: Ocean North of Island
!========================================
Object room23 "Ocean North of Island"
with
  description "You find yourself in the sea water at the north end of the island. There's only a steep cliff along the shoreline to your south and never-ending ocean to the north. Your best bet is to swim around the shoreline to the east or west.",
  n_to "That direction will only take you into deeper ocean waters.",
  s_to STEEP_CLIFF_PREVENTS_YOU,
  e_to room22,
  w_to
  [;
    print "The strong current drags you around to the west side of the island, where the large waves wash you ashore...^^";
    return room09;
  ],
  d_to "The ocean currents are too strong to go diving here.",
  before
  [;
    Dive:
      <<Go FAKE_D_OBJ>>;
    Swim:
      "Which direction?";
  ],
has light water;

!========================================
! Room 24: Deep Below Water
!========================================
Object room24 "Deep Below Water"
with
  description "You've descended to a considerable depth where you can see the enormous hulk of an ancient wreck resting on the rocky sea bed. Flashes of sunlight create a mesmerising light show on the surface of the water many metres above your head.",
  u_to room22,
  d_to "You can't go any deeper.",
  in_to room25,
  before
  [;
    Dive:
      <<Go FAKE_D_OBJ>>;
    Hint:
      if (room25 hasnt visited)
        "Enter the wreck.";
    Swim:
      <<Go FAKE_IN_OBJ>>;
  ],
has light water;

