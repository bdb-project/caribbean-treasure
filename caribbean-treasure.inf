Object "view" room21
with
  article THE,
  name 'impressive' 'view',
  description "There's ocean as far as the eye can see.",
has scenery;

!----------------------------------------
! Ocean on east side of island (floating object)
!----------------------------------------
Object "ocean"
with
  article THE,
  name 'ocean' 'sea' 'water',
  description "The ocean on this side of the island is dark blue due to the depth of the water and the rocky sea bed.",
  react_before
  [;
    Drop:
      if (self in room23 or room25)
        "Not here or it will get lost in the ocean.";
  ],
  before
  [;
    Drink:
      print_ret (string)TOO_SALTY;
  ],
  react_after
  [;
    Drop:
      if (self in room22)
      {
        print (The)noun;
        if (noun has buoyant)
        {
          print " float";
          if (noun hasnt pluralname)
            print "s";
          " on the water.";
        }
        move noun to room24;
        print " sink";
        if (noun hasnt pluralname)
          print "s";
        " below the water.";
      }
      if (self in room24)
      {
        print (The)noun;
        if (noun hasnt buoyant)
        {
          print " sink";
          if (noun hasnt pluralname)
            print "s";
          " to the bottom.";
        }
        move noun to room22;
        print " float";
        if (noun hasnt pluralname)
          print "s";
        " to the surface.";
      }
  ],
  found_in room21 room22 room23 room24 room25,
has scenery;

!========================================
! Room 22: Ocean at Foot of Cliff
!========================================
Object room22 "Ocean at Foot of Cliff"
with
  description "You're in the ocean at the foot of a high cliff at the east side of the island. The water is very deep here. You can't climb the cliff and the ocean currents are too strong to swim south or east, but you can swim around the island to the north.",
  n_to room23,
  w_to STEEP_CLIFF_PREVENTS_YOU,
  d_to
  [;
    if (scuba hasnt worn || flippers hasnt worn)
      print_ret (string)NEED_TO_WEAR_DIVING_GEAR;
    return room24;
  ],
  before
  [;
    Dive:
      <<Go FAKE_D_OBJ>>;
    Hint:
      if (room20 hasnt visited)
        "Find your stolen diving gear.";
      if (scuba hasnt worn || flippers hasnt worn)
        print_ret (string)NEED_TO_WEAR_DIVING_GEAR;
      if (room24 hasnt visited)
        "Dive, dive, dive.";
    Swim:
      <<Go FAKE_N_OBJ>>;
  ],
has light water;

!----------------------------------------
! Coast (east and north of island) (floating object)
!----------------------------------------
Object "coast"
with
  article THE,
  name 'coast' 'shore' 'shoreline',
  description "The coast is lined by a tall cliff, so there's no way to get ashore.",
  found_in room22 room23,
has scenery;

