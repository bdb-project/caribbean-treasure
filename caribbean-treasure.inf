Constant Story "Caribbean Treasure";
Constant Headline "^Copyright (c) 2025 Garry Francis^https://bdb-project.itch.io^Type ABOUT for further info and credits.^^";

Array UUID_ARRAY string "UUID://e2195f71-8171-42e4-a0b4-30c7d69a7a82//";
#Ifdef UUID_ARRAY;
#Endif;

Release 1;
Serial "251009";

!Inform 6 constants
Constant DEATH_MENTION_UNDO;
Constant MAX_CARRIED = 10;
Constant NO_SCORE;

!PunyInform constants
Constant CUSTOM_ABBREVIATIONS;
Constant OPTIONAL_EXTENDED_METAVERBS;
Constant OPTIONAL_EXTENDED_VERBSET;
Constant OPTIONAL_FULL_DIRECTIONS;
Constant OPTIONAL_PROVIDE_UNDO;
Constant RUNTIME_ERRORS 0;!0 for release, 2 for debug

!PunyInform static messages
Constant MSG_COMMENT_NO_TRANSCRIPT "Comment recorded. Use SCRIPT ON to save future comments in a transcript.^";
Constant MSG_COMMENT_TRANSCRIPT "Comment recorded.^";
Constant MSG_PARSER_NO_INPUT "You need to enter a command.";
Constant MSG_PARSER_UNKNOWN_VERB "That's not a verb I recognise.";
Constant MSG_SORRY_DEFAULT "Oh, don't apologise.";
Constant MSG_WAIT_DEFAULT "Time passes...";

!PunyInform dynamic messages
Constant MSG_CLOSE_NOT_OPEN 1000;
Constant MSG_LOCK_ALREADY_LOCKED 1001;
Constant MSG_LOCK_CLOSE_FIRST 1002;
Constant MSG_LOCK_KEY_DOESNT_FIT 1003;
Constant MSG_UNLOCK_ALREADY_UNLOCKED 1004;
Constant MSG_UNLOCK_KEY_DOESNT_FIT 1005;

Constant MSG_DIG_NO_USE 1006;

!Game-specific constants
Constant AN "an";
Constant SOME "some";
Constant THE "the";
Constant ALL_PIRATES_CLOTHES " all the pirate's clothes - shirt, coat and breeches.";
Constant CANT_CLIMB_WEARING_FLIPPERS "You can't very well climb a rope while wearing flippers.";
Constant CASTAWAY_DRAWS_KNIFE "The castaway draws a long, sharp knife and ";
Constant ENTER_CAVE "Are you waiting for an invitation? Enter the cave.";
Constant EXAMINE_OR_SEARCH "Try examining or searching the ";
Constant HEAR_OCEAN_WAVES "You can hear the ocean waves.";
Constant LEAVE_LANTERN_BEHIND "You'd better leave the lantern behind or it'll get wet.";
Constant LOOKS_LIKE_GRAPPLING_HOOK " Now it looks like a grappling hook.";
Constant NEED_TO_CLIMB_OVER_PALISADE "You'll need to climb over the palisade. You can't just walk through it.";
Constant NEED_TO_WEAR_DIVING_GEAR "You need to be wearing a full set of diving gear before you can dive.";
Constant PALISADE_IS_TOO_HIGH_TO_CLIMB "The palisade is too high to climb or jump over.";
Constant SAND_IS_TOO_DRY "The sand is too dry. As soon as you scoop it up, the edges collapse back into the hole.";
Constant STEEP_CLIFF_PREVENTS_YOU "The steep cliff prevents you going ashore here.";
Constant TOO_SALTY "It's too salty. It would make you sick.";
Constant TOO_STEEP_TO_CLIMB "It's too steep to climb.";
Constant WAVES_WOULD_WASH_YOU_ONTO_ROCKS "The ocean waves would wash you onto the jagged rocks.";
Constant YOU_CLIMB_OVER_PALISADE "You climb up the rope, balance precariously on top of the palisade, readjust the hook, lower the rope down the other side and climb down.^^";
Constant YOU_FOCUS_GLASSES_LENS "You focus the glasses' lens on the ";

!Replaced actions
Replace _UpdateDarkness;
Replace GoSub;
Replace LockSub;
Replace UnlockSub;

Include "globals.h";

!Game-specific variables
Attribute buoyant;
Attribute water;

!========================================
! Entry point routines
!========================================
[ LibraryMessages p_msg p_arg_1 p_arg_2;
  switch (p_msg)
  {
    MSG_CLOSE_NOT_OPEN:
      print_ret (CTheyreOrIts)noun, " already closed.";
    MSG_LOCK_ALREADY_LOCKED:
      print_ret (CTheyreOrIts)noun, " already locked.";
    MSG_LOCK_CLOSE_FIRST:
      "You'll have to close ", (ItOrThem)noun, " first.";
    MSG_LOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
    MSG_UNLOCK_ALREADY_UNLOCKED:
      print_ret (CTheyreOrIts)noun, " already unlocked.";
    MSG_UNLOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
    MSG_DIG_NO_USE:
      if (location has water)
        "You can't very well dig in the water.";
      if (noun == nothing && sand in location)
        <<Dig sand>>;
      "You try digging with your bare hands, then curse yourself for setting out on a treasure hunt without a spade or a shovel.";
  }
  p_arg_1 = p_arg_2;
];

Include "puny.h";

!========================================
! Initialisation
!========================================
[ Initialise;
  location = room01;
  lookmode = 2;
  no_implicit_actions = true;
  player.description = PlayerDescription;
  "^You'd always been fascinated by stories of pirates and sunken galleons and lost treasures. When you learnt how to sail a yacht, you started taking this interest a little more seriously and started studying old maps and manuscripts in various libraries.^^Then, one day, you found a musty old manuscript that hinted at the location of a pirate ship that had sunk off the coast of a small uncharted island in the Caribbean. This was what you'd been looking for! After a little more research, you found that the island was uncharted when the manuscript was written, but nothing is uncharted nowadays and you were easily able to find it on current navigation charts.^^On your next summer vacation, you rented a small yacht and sailed to the location indicated on the manuscript, where you found a small tropical island far from the normal tourist routes. You moored the yacht in a tranquil bay a few metres offshore and swam to the beach, tingling with excitement. When you explored the area along the beach, it was blocked by a steep cliff, so you retraced your steps.^^When you returned to the beach, you noticed footprints in the sand that weren't there before. They weren't yours! They started at the vegetation bordering the beach, headed into the water, then returned and disappeared back into the vegetation. The footprints were only shallow, so the owner must have been very slight of build.^^You started to panic. Could the island be inhabited by savages? How many were there? Were they friendly or were they barbaric? Might they have entered the yacht and damaged it. Should you check the yacht or should you follow the footsteps into the vegetation?^";
];

!========================================
! Room 1: Tropical Beach
!========================================
Object room01 "Tropical Beach"
with
  description "You're on a sandy beach that skirts a bay on the west coast of a small tropical island. As you look west, you can see your yacht moored in the bay. Beyond that, the crystal clear water extends to the horizon. A patch of tropical vegetation to the north follows the top of a headland that protects the bay. You can't go east, due to a rocky cliff, but you can go south around the base of the cliff.",
  n_to room07,
  s_to room05,
  w_to
  [;
    if (lantern in player)
      print_ret (string)LEAVE_LANTERN_BEHIND;
    else
      return room02;
  ],
  before
  [;
    Swim:
      <<Go FAKE_W_OBJ>>;
  ],
has light;

!----------------------------------------
! Tropical beach (floating object)
!----------------------------------------
Object "tropical beach"
with
  name 'tropical' 'beach' 'sandy',
  description
  [;
    print "The beach is covered in pure white sand";
    if (self in room01)
      ". You notice some footprints in the sand that aren't yours.";
    else
      " that forms a cresent around the east of the bay.";
  ],
  before
  [;
    Swim:
      if (self in room02)
        <<Go FAKE_E_OBJ>>;
  ],
  found_in room01 room02 room03 room05,
has scenery;

!----------------------------------------
! Sand (floating object)
!----------------------------------------
Object sand "sand"
with
  article SOME,
  name 'pure' 'white' 'sand',
  description
  [;
    print "The sand is pure white.";
    if (self in room16)
      print " Unlike the sand on the beach, this sand is saturated with sea water.";
    "";
  ],
  before
  [;
    Dig:
      if (self in room16)
        "As you dig, sea water fills the hole. You don't dig very far before you hit rock.";
      else
        print_ret (string)SAND_IS_TOO_DRY;
    Take:
      "Your pockets aren't big enough to hold all that sand.";
  ],
  found_in room01 room05 room06 room09 room16,
has scenery;

!----------------------------------------
! Bay (as seen from island) (floating object)
!----------------------------------------
Object "bay"
with
  name 'bay' 'majestic' 'view',
  description "The bay is protected by the headland so that water laps gently along the shoreline.",
  before
  [;
    Enter:
      if (self in room01)
        <<Go FAKE_W_OBJ>>;
      if (self in room03)
        <<Go FAKE_E_OBJ>>;
  ],
  found_in room01 room02 room03 room08,
has scenery;

!----------------------------------------
! Coast (as seen from island) (floating object)
!----------------------------------------
Object "coast"
with
  article THE,
  name 'coast' 'coastline' 'shore' 'shoreline',
  description "The coast of the bay is a crescent of pure white sand.",
  before
  [;
    Swim:
      if (self in room02)
        <<Go FAKE_E_OBJ>>;
  ],
  found_in room01 room02 room03 room08,
has scenery;

!----------------------------------------
! Tropical island (floating object)
!----------------------------------------
Object "tropical island"
with
  name 'tropical' 'island' 'small' 'beautiful' 'paradise',
  description
  [;
    if (self in room02 or room03)
      "It looks quite beautiful, but you can see it clearer if you go there. It's within swimming distance.";!As seen from bay
    else
      "It looks like a tropical paradise.";!As seen from elsewhere
  ],
  found_in room01 room02 room03 room05 room06 room07 room08 room09,
has scenery;

!----------------------------------------
! Headland (floating object)
!----------------------------------------
Object "headland"
with
  name 'headland',
  description
  [;
    if (self in room08)
      "The headland is elevated above this part of the island, giving a majestic view over the bay to the south. The view to the north and east are blocked by the tropical vegetation.";
    else
      "The headland to the north protects the bay from the ocean waves.";
  ],
  found_in room01 room02 room03 room08,
has scenery;

!----------------------------------------
! Horizon (floating object)
!----------------------------------------
Object "horizon"
with
  article THE,
  name 'horizon' 'azure' 'blue' 'sky',
  description "As you gaze to the west, you see where the azure blue sky meets the dark blue sea far beyond the island.",
  found_in room01 room02 room03 room08 room09,
has scenery;

!----------------------------------------
! Yacht (floating object)
!----------------------------------------
Object "yacht"
with
  name 'yacht' 'boat' 'small' 'modest',
  description
  [;
    if (self in room01)
      "It's moored in the shallow water of the bay about 50 metres to the west.";
    else
      "It's the small yacht that you rented for your summer vacation. It's only modest, as you couldn't afford anything fancy.";
  ],
  before
  [;
    Enter:
      if (self in room01)
        "You'll have to swim out to it first.";
      if (self in room02)
        <<Go FAKE_U_OBJ>>;
      "You're already on board.";
    Exit:
      if (self in room04)
        "You'll have to get on deck first.";
      if (self in room03)
        <<Go FAKE_E_OBJ>>;
      "You're not on board.";
    Swim:
      if (self in room01)
        <<Go FAKE_W_OBJ>>;
  ],
  found_in room01 room02 room03 room04,
has scenery;

!----------------------------------------
! Ocean on west side of island (floating object)
!----------------------------------------
Object "ocean"
with
  article THE,
  name 'ocean' 'sea' 'water' 'shallow' 'crystal' 'clear' 'pale' 'blue',
  description "The sea water in the bay is crystal clear and pale blue due to the shallow depth and the white sand of the sea bed.",
  before
  [;
    Drink:
      print_ret (string)TOO_SALTY;
    Enter:
      if (self in room01)
        <<Go FAKE_W_OBJ>>;
      if (self in room02)
        "You're already in it.";
      if (self in room03)
        <<Go FAKE_E_OBJ>>;
  ],
  found_in room01 room02 room03 room08,
has scenery;

!----------------------------------------
! Footprints
!----------------------------------------
Object "footprints" room01
with
  name 'footprints',
  description "These footprints can't be yours, as they were made by bare feet, whereas you're wearing sneakers. They head from the vegetation in the north, across the beach to the water and back again. You note that the footprints heading to the water aren't as deep as the ones returning from the water.",
has pluralname scenery;

!----------------------------------------
! Tropical vegetation (floating object)
!----------------------------------------
Object "tropical vegetation"
with
  article THE,
  name 'tropical' 'vegetation' 'thick' 'patch' 'of' 'undergrowth' 'tangled' 'vine' 'vines' 'palm' 'tree' 'trees',
  description "The vegetation consists of thick undergrowth, tangled vines and palm trees.",
  before
  [;
    Climb:
      "You're not a monkey.";
  ],
  found_in room01 room07 room08 room09 room10 room18,
has scenery;

!----------------------------------------
! Cliff (floating object)
!----------------------------------------
Object "rocky cliff"
with
  name 'cliff' 'rock' 'rocky' 'face' 'base' 'foot' 'of' 'very' 'high',
  description "The cliff dominates the south part of the island. It towers over you, as if the island had once been severed in two. It's very steep, so don't even think about climbing it.",
  before
  [;
    Climb:
      "It's far too steep to climb, even for a mountain goat.";
  ],
  found_in room01 room05 room06,
has scenery;

!========================================
! Room 2: Bay West of Island
!========================================
Object room02 "Bay West of Island"
with
  description "You're bobbing around in the sea water adjacent to the hull of your yacht. It's moored in a bay off the west coast of a beautiful tropical island. You can go up to board the yacht or swim to the beach, which is just a short distance to the east.",
  e_to room01,
  u_to room03,
  cant_go "You can only swim east to the beach or go up to board the yacht.",
  before
  [;
    Dive:
      "The water in the bay isn't deep enough for diving.";
    Hint:
      if (room03 hasnt visited)
        "Try boarding your yacht (or just go up) to see what's on board.";
    Swim:
      <<Go FAKE_E_OBJ>>;
  ],
has light water;

!----------------------------------------
! Hull
!----------------------------------------
Object "hull" room02
with
  article THE,
  name 'hull' 'aida' 'side',
  description "It has the name 'Aida' painted on the side, but that's not important.",
has scenery;

!========================================
! Room 3: Deck of Yacht
!========================================
Object room03 "Deck of Yacht"
with
  description
  [;
    print "You're on the deck of your yacht. Nothing seems to be damaged";
    if (scuba notin self)
    {
      print ", but you notice that your scuba gear has been taken";
      if (scuba has moved)
        print ". Fortunately, you've now found it";
    }
    ". The yacht is moored about 50 metres from the shore of a beautiful tropical island. If you jump overboard, you can swim to the beach to the east. Otherwise, some steps lead down to the cabin.";
  ],
  e_to room02,
  d_to room04,
  in_to room04,
  before
  [;
    Dive, Jump, Swim:
      <<Go FAKE_E_OBJ>>;
    Hint:
      if (room04 hasnt visited)
        "Try going down the stairs to see what's below deck.";
  ],
has light;

!----------------------------------------
! Deck
!----------------------------------------
Object "deck" room03
with
  article THE,
  name 'deck',
  description "The deck is quite clean, apart from some fresh seagull poop.",
has scenery;

!----------------------------------------
! Seagull poop
!----------------------------------------
Object "seagull poop" room03
with
  article SOME,
  name 'seagull' 'poop' 'poo' 'droppings',
  description "It's the inevitable scourge of the sailor. You wish seagulls were toilet trained.",
  before
  [;
    Take:
      "Don't be disgusting.";
  ],
has scenery;

!----------------------------------------
! Steps (floating object)
!----------------------------------------
Object "steps"
with
  name 'steps' 'stairs' 'step' 'stair',
  description
  [;
    print "They're narrow steps that go ";
    if (self in room04)
      "up to the deck.";
    else
      "down to the cabin.";
  ],
  before
  [;
    Climb, Enter:
      if (self in room04)
        <<Go FAKE_U_OBJ>>;
      else
        <<Go FAKE_D_OBJ>>;
  ],
  found_in room03 room04,
has pluralname scenery;

!========================================
! Room 4: Cabin of Yacht
!========================================
Object room04 "Cabin of Yacht"
with
  description "You're in the cabin of your yacht. The interior shows signs of a recent looting and many of the furnishings are now damaged. There are objects scattered everywhere, but nothing seems to have been taken. Some steps go up to the deck outside the cabin.",
  u_to room03,
  out_to room03,
  before
  [;
    Hint:
      if (glasses in nothing)
        print_ret (string)EXAMINE_OR_SEARCH, "cabin to see if anything is missing.";
  ],
has light;

!----------------------------------------
! Cabin
!----------------------------------------
Object "cabin" room04
with
  article THE,
  name 'cabin' 'interior' 'furnishings' 'object' 'objects' 'mess' 'bunk',
  description
  [;
    print "It's a bit of a mess, but you can clean it up later.";
    if (glasses in nothing)
    {
      move glasses to location;
      print " In amongst the mess, you find a pair of glasses.";
    }
    "";
  ],
  before
  [;
    Search:
      <<Examine self>>;
  ],
has scenery;

!----------------------------------------
! Glasses
!----------------------------------------
Object glasses "glasses"
with
  article "a pair of",
  name 'pair' 'of' 'reading' 'glasses' 'spectacles' 'specs' 'very' 'thick' 'lens' 'lenses',
  description "They look like reading glasses with very thick lenses, but they're not yours. Perhaps the intruder dropped them when they rifled through your cabin.",
  before
  [;
    Wear:
      if (location has light)
        "Whoa, everything looks horribly distorted. You feel disoriented, so you take them off again. Upon closer inspection, you see that the lenses are like magnifying glasses. Whoever wore these must have had very poor vision.";
      else
        "Er, nope, they aren't night vision glasses and they don't help you see in the dark, so you take them off again.";
  ],
has clothing pluralname;

!========================================
! Room 5: Group of Jagged Rocks
!========================================
Object room05 "Group of Jagged Rocks"
with
  description "You're at a group of jagged rocks projecting from the sand on the south coast of the island. The rocks protect the quiet bay towards the north while the open ocean is to the south. You can also follow the base of the high cliff towards the east.",
  n_to room01,
  s_to WAVES_WOULD_WASH_YOU_ONTO_ROCKS,
  e_to room06,
  before
  [;
    Hint:
      if (hook in nothing)
        "Try looking under the plank or picking it up.";
    Listen:
      print_ret (string)HEAR_OCEAN_WAVES;
    Swim:
      <<Go FAKE_S_OBJ>>;
  ],
has light;

!----------------------------------------
! Jagged rocks (floating object)
!----------------------------------------
Object "jagged rocks"
with
  name 'group' 'of' 'jagged' 'rock' 'rocks' 'sentinels',
  description "The jagged rocks poke through the sand like sentinels standing guard over the cliff at the south end of the island.",
  before
  [;
    Pull, Push, Take:
      "They're as solid as a rock. (They're rocks. Solid as a rock. Get it? Oh, forget it. Good puns are wasted on some people.)";
  ],
  found_in room05 room06,
has pluralname scenery;

!----------------------------------------
! South coast (floating object)
!----------------------------------------
Object "south coast"
with
  article THE,
  name 'south' 'coast' 'southern' 'extremity',
  description "This is the southern extremity of the island, between the rocks and the ocean.",
  found_in room05 room06,
has scenery;

!----------------------------------------
! Wooden plank
!----------------------------------------
Object plank "wooden plank" room05
with
  name 'wooden' 'plank',
  description "It looks like the plank off the hull of a ship.",
  before
  [;
    Burn:
      if (CantBeLit())
        rtrue;
      print_ret (string)YOU_FOCUS_GLASSES_LENS, "plank and adjust the beam of sunlight until you get a strong point of light, but nothing happens. Maybe the plank is too wet. After a while, you give up.";
    LookUnder:
      if (self hasnt moved)
      {
        print "There's nothing but sand.";
        if (hook in nothing)
        {
          move hook to location;
          print " Oh, wait, there's a hook pressed into the sand, so you move it out from under the plank.";
        }
        "";
      }
  ],
  after
  [;
    Take:
      if (hook in nothing)
      {
        move hook to location;
        "When you pick up the plank, you reveal a hook pressed into the sand.";
      }
  ],
has buoyant;

!----------------------------------------
! Metal hook
!----------------------------------------
Object hook "metal hook"
with
  name 'metal' 'hook',
  description "It's a metal hook that looks like something from a ship's rigging.",
  before
  [;
    Tie:
      if (CantBeTied())
        rtrue;
      move rope to limbo;
      move rope_with_hook to parent(self);
      move self to limbo;
      PronounNotice(rope_with_hook);
      "You tie the hook to the rope.", (string)LOOKS_LIKE_GRAPPLING_HOOK;
  ],
has;

!========================================
! Room 6: Foot of Cliff
!========================================
Object room06 "Foot of Cliff"
with
  description "You're at the foot of a very high cliff that looks like it would be constantly washed by the ocean waves during high tides and rough seas. Deep sand has collected between the rocks. A large outcrop of rock prevents further progress around the coastline to the east, although it does contain a sea cave that you could enter. You can return to the beach to the west.",
  s_to WAVES_WOULD_WASH_YOU_ONTO_ROCKS,
  e_to room16,
  w_to room05,
  in_to room16,
  before
  [;
    Go:
      if (selected_direction == e_to or in_to)
        StartDaemon(room16);
      rfalse;
    Hint:
      if (rope in nothing)
        print_ret (string)EXAMINE_OR_SEARCH, "anchor.";
      if (room16 hasnt visited)
        print_ret (string)ENTER_CAVE;
    Listen:
      print_ret (string)HEAR_OCEAN_WAVES;
    Swim:
      <<Go FAKE_S_OBJ>>;
  ],
has light;

!----------------------------------------
! Outcrop of rock
!----------------------------------------
Object "outcrop of rock" room06
with
  article AN,
  name 'outcrop' 'of' 'rock' 'large',
  description "The outcrop of rock is an extension of the cliff that prevents further exploration to the east, unless you're prepared to enter the sea cave.",
  before
  [;
    Climb:
      "You climb a metre or so up the outcrop, but the sharp rock cuts into your fingers, so you jump back down.";
  ],
has scenery;

!----------------------------------------
! Sea cave (floating object)
!----------------------------------------
Object "sea cave"
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'large' or 'sea' or 'cave' or 'entrance')
    {
      i++;
      if (nw == 'sea')
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description "The sea cave is mostly below the high-tide mark. Be careful of getting caught inside the cave if the sea level rises.",
  before
  [;
    Enter:
      if (self in room06)
        <<Go FAKE_E_OBJ>>;
    Exit:
      if (self in room16)
        <<Go FAKE_W_OBJ>>;
  ],
  found_in room06 room16,
has scenery;

!----------------------------------------
! High-tide mark (floating object)
!----------------------------------------
Object "high-tide mark"
with
  name 'high-tide' 'high' 'tide' 'mark' 'marking',
  description "The high-tide mark is above your head.",
  found_in room06 room16,
has scenery;

!----------------------------------------
! Old anchor
!----------------------------------------
Object "old anchor" room06
with
  article AN,
  name 'old' 'anchor',
  description
  [;
    print "It's a rusty old ship's anchor that's half-submerged in the sand.";
    if (rope in nothing)
      print " You wonder if you could dig it out.";
    "";
  ],
  before
  [;
    Dig, Search:
      print "You search the anchor, then try to dig it out of the sand, but it's way too deep.";
      if (rope in nothing)
      {
        move rope to location;
        print " However, you do discover a rope.";
      }
      "";
    Pull, Push, Take:
      "You can't be serious. It's half-submerged in the sand. Even if it wasn't, it's too heavy to carry.";
  ],
has static;

!----------------------------------------
! Rope
!----------------------------------------
Object rope "rope"
with
  name 'rope',
  description "It's a short length of rope that you found on the beach.",
  before
  [;
    ThrowAt:
      "You hang onto one end of the rope and throw the other end. It has nothing to hook onto, so you gather it up again.";
    Tie:
      if (CantBeTied())
        rtrue;
      move hook to limbo;
      move rope_with_hook to parent(self);
      move self to limbo;
      PronounNotice(rope_with_hook);
      "You tie the rope to the hook.", (string)LOOKS_LIKE_GRAPPLING_HOOK;
  ],
has buoyant;

!----------------------------------------
! Rope with a hook attached
!----------------------------------------
Object rope_with_hook "rope with a hook attached"
with
  name 'rope' 'with' 'grappling' 'hook' 'attached',
  description "It's a short length of rope tied to the hook that you found on the beach. It now looks like a grappling hook.",
  before
  [;
    ThrowAt:
      if (second == player)
        "The hook hits you in the head. Youch! You've done some silly things in your life and that's another one to add to the list.";
      if (second ~= palisade || palisade notin location)
      {
        move self to location;
        "The rope and hook land on the ground. That was a pretty pointless exercise.";
      }
      remove self;
      move hanging_rope to location;
      PronounNotice(hanging_rope);
      "You hang onto the end of the rope and throw the hook over the palisade. It catches. You pull it tight and it feels sturdy.";
    Tie:
      "If you want to tie the rope to something else, you'll have to untie it from the hook first.";
    Untie:
      move hook to parent(self);
      move rope to parent(self);
      remove self;
      PronounNotice(rope);
      "You untie the rope from the hook.";
  ],
has;

!========================================
! Room 7: Tropical Vegetation
!========================================
Object room07 "Tropical Vegetation"
with
  description "You're in a thick patch of tropical vegetation that blocks your view of the beach to the south. It extends to the west, but thins out to the north and east.",
  n_to room10,
  s_to room01,
  e_to room13,
  w_to room08,
has light;

!========================================
! Room 8: Headland
!========================================
Object room08 "Headland"
with
  description "The headland provides a majestic view over the bay to the south. A faint track winds north and east through the vegetation.",
  n_to room09,
  e_to room07,
has light;

!----------------------------------------
! Track (floating object)
!----------------------------------------
Object "track"
with
  name 'faint' 'track' 'tracks' 'path' 'paths',
  description
  [;
    print "The track winds through the vegetation to the ";
    if (self in room10)
      "north, south, east and west.";
    if (self in room08)
      print "north";
    else
      print "south";
    " and east.";
  ],
  found_in room08 room09 room10,
has scenery;

!========================================
! Room 9: Ocean Beach
!========================================
Object room09 "Ocean Beach"
with
  description "This strip of beach is isolated by thick vegetation. However, there are faint tracks to the south and east. You can't see the bay from here because of the thick vegetation to the south. There's a heavy surf rolling in from the west, which is why you couldn't moor here.",
  s_to room08,
  e_to room10,
  w_to "The waves are too strong to enter the water here.",
  before
  [;
    Listen:
      print_ret (string)HEAR_OCEAN_WAVES;
    Swim:
      <<Go FAKE_W_OBJ>>;
  ],
has light;

!----------------------------------------
! Ocean (floating object)
!----------------------------------------
Object "ocean"
with
  article THE,
  name 'ocean' 'sea' 'water' 'waves' 'heavy' 'surf',
  description
  [;
    print "The ocean waves are rolling in from the ";
    if (self in room09)
      "west.";
    else
      "south.";
  ],
  before
  [;
    Drink:
      print_ret (string)TOO_SALTY;
    Enter:
      if (self in room09)
        <<Go FAKE_W_OBJ>>;
      else
        <<Go FAKE_S_OBJ>>;
  ],
  found_in room05 room06 room09,
has scenery;

!----------------------------------------
! Ocean beach
!----------------------------------------
Object "ocean beach" room09
with
  article AN,
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'ocean' or 'beach' or 'strip' or 'of' or 'sandy')
    {
      i++;
      if (nw == 'ocean')
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description "This is a short length of sandy beach pounded by the ocean waves rolling in from the west.",
  before
  [;
    Dig:
      print_ret (string)SAND_IS_TOO_DRY;
  ],
has scenery;

